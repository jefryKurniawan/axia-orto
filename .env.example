APP_NAME=AxiaOrto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL (React SPA dev server)
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MySQL for shared hosting)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=axiadb
DB_USERNAME=root
DB_PASSWORD=

# Cache (file driver — no Redis on shared hosting)
CACHE_DRIVER=file
FILESYSTEM_DISK=local

# Queue (database driver — processed by cron)
QUEUE_CONNECTION=database

# Session (file driver)
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_DRIVER=log

# Sanctum (SPA authentication)
# Comma-separated list of domains that should be considered "stateful"
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
